{
  "name": "gemini-monitor-app",
  "type": "module",
  "private": true,
  "scripts": {
    "dev:backend": "bun run src/backend/index.ts",
    "dev:frontend": "vite",
    "dev": "concurrently \"bun run dev:backend\" \"bun run dev:frontend\"",
    "build": "vite build",
    "analyze": "vite build --mode analyze",
    "preview": "vite preview",
    "test:frontend": "vitest run",
    "test:backend": "NODE_ENV=test bun test src/backend",
    "test": "bun run test:frontend && bun run test:backend"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@tanstack/react-virtual": "^3.13.24",
    "chokidar": "^5.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^4.1.5",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.0.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^4.1.5"
  }
}
